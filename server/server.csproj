<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.10" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.10" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.2.3" />
  </ItemGroup>

  <!-- TodoApi.Tests lives in a subfolder of this project for monorepo convenience; exclude it explicitly so
       the default recursive glob doesn't pull its generated/compiled files into this project's compilation. -->
  <ItemGroup>
    <Compile Remove="TodoApi.Tests/**/*.cs" />
    <Content Remove="TodoApi.Tests/**/*" />
    <None Remove="TodoApi.Tests/**/*" />
    <EmbeddedResource Remove="TodoApi.Tests/**/*" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Data/Seeds/TodoSeeds.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
